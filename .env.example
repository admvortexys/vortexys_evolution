# =============================================================================
# VORTEXYS - example environment variables
# Copy this file to .env and adjust the values before the first boot.
# =============================================================================

# --- App / runtime -----------------------------------------------------------
NODE_ENV=production
PORT=3001
HOST_PORT=80

# --- Database ----------------------------------------------------------------
DB_HOST=postgres
DB_PORT=5432
DB_NAME=vortexys
DB_USER=vortexys
DB_PASSWORD=TROQUE_SENHA_DO_BANCO_AQUI
# Enable only if your Postgres requires TLS/SSL
DB_SSL=false

# --- Security ----------------------------------------------------------------
# Generate with: openssl rand -hex 32
JWT_SECRET=TROQUE_POR_UMA_CHAVE_HEX_64_CHARS
# Used to encrypt sensitive data at rest. If omitted, JWT_SECRET is used.
DATA_ENCRYPTION_KEY=TROQUE_POR_OUTRA_CHAVE_HEX_64_CHARS
ACCESS_TOKEN_EXPIRES_IN=15m

# --- URLs / CORS -------------------------------------------------------------
# Frontend origin allowed to call the API
ALLOWED_ORIGIN=http://localhost
# Public frontend URL used in OS portal links and websocket origin checks
APP_URL=http://localhost
# Frontend -> backend base path
VITE_API_URL=/api

# --- White-label -------------------------------------------------------------
VITE_COMPANY_NAME=Vortexys
VITE_PRIMARY_COLOR=#a855f7
VITE_SECONDARY_COLOR=#f97316
# Public PNG/SVG URL. Leave blank to use the default logo.
VITE_LOGO_URL=

# --- Initial admin -----------------------------------------------------------
# If you use deploy.sh, missing values can be requested or generated there.
ADMIN_NAME=Administrador
ADMIN_USERNAME=administrador
ADMIN_EMAIL=admin@seudominio.com
# Minimum: 8 chars with 1 uppercase, 1 lowercase and 1 number
ADMIN_PASSWORD=

# --- WhatsApp / Evolution API ------------------------------------------------
# In Docker, the backend already talks to the internal Evolution service URL.
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=TROQUE_CHAVE_EVOLUTION_AQUI
# Generate with: openssl rand -hex 24
WA_WEBHOOK_SECRET=TROQUE_POR_UM_SEGREDO_HEX_48_CHARS