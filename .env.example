# =============================================================================
#  VORTEXYS — Configuração da instância
#  Copie para .env e edite:  cp .env.example .env && nano .env
# =============================================================================

# ── Banco de dados ────────────────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=vortexys
DB_USER=vortexys
DB_PASSWORD=TROQUE_SENHA_DO_BANCO_AQUI

# ── JWT — gere com: openssl rand -hex 32 ─────────────────────────────────────
JWT_SECRET=TROQUE_POR_STRING_ALEATORIA_MINIMO_32_CHARS
JWT_EXPIRES_IN=7d

# ── Segurança ─────────────────────────────────────────────────────────────────
# Domínio que pode chamar a API (CORS)
ALLOWED_ORIGIN=http://localhost

# ── White-label — identidade visual do cliente ────────────────────────────────
VITE_COMPANY_NAME=Vortexys
VITE_PRIMARY_COLOR=#a855f7
VITE_SECONDARY_COLOR=#f97316
# URL pública do logo PNG/SVG — deixe vazio para usar o ícone padrão ⚡
VITE_LOGO_URL=
# Endereço da API (não altere em produção com nginx)
VITE_API_URL=/api

# ── Admin inicial (criado no primeiro boot) ───────────────────────────────────
# O usuário será forçado a trocar a senha no primeiro login.
ADMIN_NAME=Administrador
ADMIN_EMAIL=admin@seudominio.com
ADMIN_PASSWORD=TROQUE_SENHA_ADMIN_AQUI

# ── WhatsApp — Evolution API ──────────────────────────────────────────────────
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=TROQUE_CHAVE_EVOLUTION_AQUI
# URL pública desta API para receber webhooks do Evolution
API_PUBLIC_URL=http://SEU_DOMINIO_OU_IP/api

# ── Porta do servidor (opcional — padrão: 80) ─────────────────────────────────
# HOST_PORT=80
