# =============================================
# VORTEXYS — configuração da instância
# Copie para .env e edite para cada cliente
# =============================================

# Banco de dados
DB_HOST=postgres
DB_PORT=5432
DB_NAME=vortexys
DB_USER=vortexys
DB_PASSWORD=vortexys2026

# JWT (troque por string aleatória longa em produção)
JWT_SECRET=troque_esse_secret_por_algo_seguro_em_producao
JWT_EXPIRES_IN=7d

# White-label — aparece no frontend e email
VITE_COMPANY_NAME=Vortexys
VITE_PRIMARY_COLOR=#b44fff
VITE_SECONDARY_COLOR=#ff6b2b
VITE_LOGO_URL=
VITE_API_URL=/api

# Admin inicial (criado no primeiro boot)
ADMIN_NAME=Administrador
ADMIN_EMAIL=admin@empresa.com
ADMIN_PASSWORD=admin123

# Segurança (OBRIGATÓRIO — use senhas longas e aleatórias)
JWT_SECRET=TROQUE_POR_SEGREDO_ALEATORIO_MINIMO_32_CHARS
JWT_REFRESH_SECRET=TROQUE_POR_OUTRO_SEGREDO_ALEATORIO_32_CHARS
JWT_EXPIRES_IN=15m
ALLOWED_ORIGIN=https://seudominio.com

# Admin inicial (senha mínima 12 chars — usuário vai ser forçado a trocar)
ADMIN_EMAIL=admin@seudominio.com
ADMIN_PASSWORD=TroqueEstaSenha2026!
ADMIN_NAME=Administrador

# ── WhatsApp ──────────────────────────────────────────────────────────────
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=vortexys_evo_key
# URL pública da API (para o webhook do Evolution chegar até cá)
API_PUBLIC_URL=http://seu-dominio.com/api
