# =============================================================================
#  Vortexys — .gitignore
# =============================================================================

# ── Segredos — NUNCA versionar ────────────────────────────────────────────────
.env
*.pem
*.key
*.cert
*.p12
secrets/

# ── Node / npm ────────────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/
backend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
package-lock.json
yarn.lock
pnpm-lock.yaml

# ── Build do frontend ─────────────────────────────────────────────────────────
frontend/dist/
frontend/.vite/
frontend/build/

# ── Docker volumes locais ─────────────────────────────────────────────────────
pgdata/
redis_data/
evolution_data/

# ── Backups de banco ──────────────────────────────────────────────────────────
*.sql.bak
backup_*.sql
dumps/

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
*.log.*

# ── Sistema operacional ───────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini

# ── IDEs e editores ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath

# ── Temporários ───────────────────────────────────────────────────────────────
tmp/
temp/
*.tmp
*.cache

# ── Coverage / testes ─────────────────────────────────────────────────────────
coverage/
.nyc_output/
