FROM node:20-alpine AS builder
WORKDIR /app
COPY package*.json ./
RUN npm install
COPY . .
ARG VITE_API_URL=/api
ARG VITE_COMPANY_NAME=Vortexys
ARG VITE_PRIMARY_COLOR=#b44fff
ARG VITE_SECONDARY_COLOR=#ff6b2b
ARG VITE_LOGO_URL=
ENV VITE_API_URL=$VITE_API_URL
ENV VITE_COMPANY_NAME=$VITE_COMPANY_NAME
ENV VITE_PRIMARY_COLOR=$VITE_PRIMARY_COLOR
ENV VITE_SECONDARY_COLOR=$VITE_SECONDARY_COLOR
ENV VITE_LOGO_URL=$VITE_LOGO_URL
RUN npm run build

FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
